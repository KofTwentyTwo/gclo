<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>gclo</AssemblyName>
    <RootNamespace>gclo.Cli</RootNamespace>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\gclo.Engine\gclo.Engine.csproj" />
    <ProjectReference Include="..\gclo.ViewModels\gclo.ViewModels.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- The test suite drives internal command cores with injected collaborators. -->
    <InternalsVisibleTo Include="gclo.Cli.Tests" />
  </ItemGroup>

</Project>
