# Analyzer tuning local to gclo.Cli.Tests (inherits the repo root .editorconfig).
# Mirrors the gclo.Engine.Tests suppressions, which are keyed to that project's
# path in the root file and therefore do not reach this one.
[*.cs]
# CA1707: xunit's Method_Scenario_Expectation naming uses underscores by convention.
dotnet_diagnostic.CA1707.severity = none
# CA1861: inline array arguments keep test data at the assertion site; each test runs once,
# so the "repeated allocation" concern does not apply.
dotnet_diagnostic.CA1861.severity = none
