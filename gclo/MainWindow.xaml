<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="gclo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:gclo"
    xmlns:vm="using:gclo.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="gclo">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <MenuBar Grid.Row="0">
            <MenuBarItem Title="File">
                <MenuFlyoutItem Text="Settings…" Click="SettingsMenuItem_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Exit" Click="ExitMenuItem_Click" />
            </MenuBarItem>
            <MenuBarItem Title="View">
                <MenuFlyoutItem Text="Activity log…" Click="ActivityLogMenuItem_Click" />
            </MenuBarItem>
            <MenuBarItem Title="Help">
                <MenuFlyoutItem Text="View on GitHub" Click="GitHubMenuItem_Click" />
                <MenuFlyoutItem Text="Check for updates…" Click="CheckForUpdatesMenuItem_Click" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="About gclo…" Click="AboutMenuItem_Click">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Key="F1" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
            </MenuBarItem>
        </MenuBar>

        <Grid Grid.Row="1" Padding="20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Token first: it determines which organizations the dropdown can offer -->
        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <PasswordBox
                Grid.Column="0"
                Header="Personal access token"
                PlaceholderText="ghp_..."
                PasswordChanged="TokenBox_PasswordChanged" />
            <ComboBox
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                Header="Organization or account"
                IsEditable="True"
                ItemsSource="{x:Bind ViewModel.Organizations, Mode=OneTime}"
                PlaceholderText="paste a token first, or type an org"
                Text="{x:Bind ViewModel.Organization, Mode=TwoWay}" />
            <ProgressRing
                Grid.Column="2"
                Width="20"
                Height="20"
                Margin="0,0,0,8"
                VerticalAlignment="Bottom"
                IsActive="{x:Bind ViewModel.IsLoadingOrgs, Mode=OneWay}" />
        </Grid>

        <!-- Target folder + subfolder option + concurrency -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox
                Grid.Column="0"
                Header="Target folder"
                PlaceholderText="C:\src\my-org"
                Text="{x:Bind ViewModel.TargetFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button
                Grid.Column="1"
                VerticalAlignment="Bottom"
                Content="Browse..."
                Click="BrowseButton_Click" />
            <CheckBox
                Grid.Column="2"
                MinWidth="0"
                VerticalAlignment="Bottom"
                Content="{x:Bind OrgSubfolderLabel(ViewModel.Organization), Mode=OneWay}"
                IsChecked="{x:Bind ViewModel.CreateOrgSubfolder, Mode=TwoWay}" />
            <NumberBox
                Grid.Column="3"
                Header="Parallel"
                Minimum="1"
                Maximum="64"
                SpinButtonPlacementMode="Inline"
                Value="{x:Bind ViewModel.MaxConcurrencyValue, Mode=TwoWay}" />
        </Grid>

        <!-- Where the clones will actually land -->
        <TextBlock
            Grid.Row="2"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            TextWrapping="Wrap">
            <Run Text="Repositories will be created like:" />
            <Run FontWeight="SemiBold" Text="{x:Bind ViewModel.TargetPreview, Mode=OneWay}" />
        </TextBlock>

        <!-- Actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="12">
            <Button
                MinWidth="110"
                Style="{StaticResource AccentButtonStyle}"
                Content="Load repos"
                Command="{x:Bind ViewModel.LoadReposCommand, Mode=OneTime}" />
            <ProgressRing
                Width="20"
                Height="20"
                VerticalAlignment="Center"
                IsActive="{x:Bind ViewModel.IsLoadingRepos, Mode=OneWay}" />
            <Button
                MinWidth="110"
                Content="Sync selected"
                Command="{x:Bind ViewModel.SyncCommand, Mode=OneTime}" />
            <Button
                MinWidth="90"
                Content="Cancel"
                Command="{x:Bind ViewModel.SyncCancelCommand, Mode=OneTime}" />
            <Button
                MinWidth="110"
                Content="Retry failed"
                Command="{x:Bind ViewModel.RetryFailedCommand, Mode=OneTime}"
                Visibility="{x:Bind AnyFailedVisibility(ViewModel.CompletedCount, ViewModel.IsRunning), Mode=OneWay}" />
            <Button
                MinWidth="110"
                Content="Open folder"
                Click="OpenFolderButton_Click"
                Visibility="{x:Bind local:StatusFormat.VisibleIf(ViewModel.HasCompletedRun), Mode=OneWay}" />
        </StackPanel>

        <!-- Overall progress -->
        <Grid Grid.Row="4" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="4">
                <ProgressBar
                    Maximum="{x:Bind ViewModel.TotalCount, Mode=OneWay}"
                    Value="{x:Bind ViewModel.CompletedCount, Mode=OneWay}" />
                <TextBlock
                    Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap" />
            </StackPanel>
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Top"
                Text="{x:Bind local:StatusFormat.Fraction(ViewModel.CompletedCount, ViewModel.TotalCount), Mode=OneWay}" />
        </Grid>

        <!-- Table header: fixed column widths mirrored by the row template below -->
        <Grid Grid.Row="5" Padding="12,0,12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="80" />
            </Grid.ColumnDefinitions>
            <CheckBox
                Grid.Column="0"
                MinWidth="0"
                Padding="0"
                VerticalAlignment="Center"
                ToolTipService.ToolTip="Select all"
                IsChecked="{x:Bind ViewModel.AllSelected, Mode=TwoWay}" />
            <Button
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Left"
                Background="Transparent"
                BorderThickness="0"
                Padding="0,4,0,4"
                FontWeight="SemiBold"
                Content="{x:Bind SortHeader('Name', ViewModel.SortColumn, ViewModel.SortDescending), Mode=OneWay}"
                Command="{x:Bind ViewModel.SortCommand, Mode=OneTime}"
                CommandParameter="Name" />
            <Button
                Grid.Column="2"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Left"
                Background="Transparent"
                BorderThickness="0"
                Padding="0,4,0,4"
                FontWeight="SemiBold"
                Content="{x:Bind SortHeader('Status', ViewModel.SortColumn, ViewModel.SortDescending), Mode=OneWay}"
                Command="{x:Bind ViewModel.SortCommand, Mode=OneTime}"
                CommandParameter="Status" />
            <Button
                Grid.Column="3"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Left"
                Background="Transparent"
                BorderThickness="0"
                Padding="0,4,0,4"
                FontWeight="SemiBold"
                Content="{x:Bind SortHeader('Branch', ViewModel.SortColumn, ViewModel.SortDescending), Mode=OneWay}"
                Command="{x:Bind ViewModel.SortCommand, Mode=OneTime}"
                CommandParameter="Branch" />
            <Button
                Grid.Column="4"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Left"
                Background="Transparent"
                BorderThickness="0"
                Padding="0,4,0,4"
                FontWeight="SemiBold"
                Content="{x:Bind SortHeader('Archived', ViewModel.SortColumn, ViewModel.SortDescending), Mode=OneWay}"
                Command="{x:Bind ViewModel.SortCommand, Mode=OneTime}"
                CommandParameter="Archived" />
        </Grid>

        <!-- Per-repo table body -->
        <ListView
            Grid.Row="6"
            ItemsSource="{x:Bind ViewModel.Repos, Mode=OneTime}"
            SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="12,0,12,0" />
                    <Setter Property="MinHeight" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:RepoItemViewModel">
                    <Grid Padding="0,6,0,6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <CheckBox
                            Grid.Row="0"
                            Grid.Column="0"
                            MinWidth="0"
                            Padding="0"
                            VerticalAlignment="Center"
                            IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            TextTrimming="CharacterEllipsis"
                            Text="{x:Bind Name, Mode=OneTime}" />
                        <StackPanel
                            Grid.Row="0"
                            Grid.Column="2"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Spacing="2">
                            <TextBlock
                                Text="{x:Bind StatusText, Mode=OneWay}"
                                Foreground="{x:Bind local:StatusFormat.BrushFor(Status), Mode=OneWay}" />
                            <ProgressBar
                                Maximum="1"
                                Value="{x:Bind ProgressValue, Mode=OneWay}"
                                IsIndeterminate="{x:Bind IsIndeterminate, Mode=OneWay}"
                                Visibility="{x:Bind local:StatusFormat.VisibleIf(ShowProgress), Mode=OneWay}" />
                        </StackPanel>
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="3"
                            VerticalAlignment="Center"
                            TextTrimming="CharacterEllipsis"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind BranchText, Mode=OneTime}" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="4"
                            VerticalAlignment="Center"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Archived"
                            Visibility="{x:Bind local:StatusFormat.VisibleIf(IsArchived), Mode=OneTime}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="5"
                            TextWrapping="Wrap"
                            Foreground="Crimson"
                            Text="{x:Bind Error, Mode=OneWay}"
                            Visibility="{x:Bind local:StatusFormat.VisibleIf(HasError), Mode=OneWay}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        </Grid>
    </Grid>
</Window>
