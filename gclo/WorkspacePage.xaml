<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="gclo.WorkspacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:gclo"
    xmlns:vm="using:gclo.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Sortable column header: quiet button, muted semibold label; left padding
             stays 0 so header text aligns exactly with the row cells below. -->
        <Style x:Key="ColumnHeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0,4,4,4" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>
        <!-- The per-column funnel that opens that column's filter flyout. -->
        <Style x:Key="ColumnFilterButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Padding="20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <VisualStateManager.VisualStateGroups>
            <!-- Driven by UpdateToolbarLayout (measured widths, not window width, so
                 text scaling and localization count too). The markup default is the
                 narrow two-row toolbar; this state lifts the action buttons back
                 beside the filter bar when everything fits on one row. -->
            <VisualStateGroup x:Name="ToolbarLayoutStates">
                <VisualState x:Name="ToolbarTwoRow" />
                <VisualState x:Name="ToolbarSingleRow">
                    <VisualState.Setters>
                        <Setter Target="IdleActions.(Grid.Row)" Value="0" />
                        <Setter Target="IdleActions.(Grid.Column)" Value="2" />
                        <Setter Target="IdleActions.(Grid.ColumnSpan)" Value="1" />
                        <Setter Target="IdleActions.Margin" Value="0" />
                        <Setter Target="RunningActions.(Grid.Row)" Value="0" />
                        <Setter Target="RunningActions.(Grid.Column)" Value="2" />
                        <Setter Target="RunningActions.(Grid.ColumnSpan)" Value="1" />
                        <Setter Target="RunningActions.Margin" Value="0" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <!-- ============================================================ State 1
             Connect card, shown until the first successful load in this workspace. -->
        <ScrollViewer
            Grid.Row="0"
            VerticalScrollBarVisibility="Auto"
            Visibility="{x:Bind local:StatusFormat.VisibleIfNot(ViewModel.HasLoadedRepos), Mode=OneWay}">
            <Border
                MaxWidth="480"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="24"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="Connect to GitHub" />

                    <!-- ContentControl: panels have no IsEnabled; a disabled Control disables its subtree. -->
                    <ContentControl
                        HorizontalContentAlignment="Stretch"
                        IsEnabled="{x:Bind ViewModel.CanEditInputs, Mode=OneWay}"
                        IsTabStop="False">
                    <StackPanel Spacing="12">
                        <PasswordBox
                            x:Name="TokenBox"
                            AutomationProperties.AutomationId="ConnectTokenBox"
                            Header="Personal access token"
                            PlaceholderText="ghp_…"
                            PasswordChanged="TokenBox_PasswordChanged" />
                        <HyperlinkButton
                            Padding="0"
                            Content="How to create a token"
                            NavigateUri="https://github.com/settings/tokens" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox
                                Grid.Column="0"
                                AutomationProperties.AutomationId="ConnectOrgBox"
                                HorizontalAlignment="Stretch"
                                Header="Organization or account"
                                IsEditable="True"
                                ItemsSource="{x:Bind ViewModel.Organizations, Mode=OneTime}"
                                PlaceholderText="Paste a token first, or type an org"
                                Text="{x:Bind ViewModel.Organization, Mode=TwoWay}" />
                            <ProgressRing
                                Grid.Column="1"
                                Width="20"
                                Height="20"
                                Margin="0,0,0,8"
                                VerticalAlignment="Bottom"
                                AutomationProperties.Name="Loading organizations"
                                IsActive="{x:Bind ViewModel.IsLoadingOrgs, Mode=OneWay}" />
                        </Grid>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Grid.Column="0"
                                AutomationProperties.AutomationId="ConnectTargetBox"
                                Header="Target folder"
                                PlaceholderText="C:\src\my-org"
                                Text="{x:Bind ViewModel.TargetFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button
                                Grid.Column="1"
                                AutomationProperties.AutomationId="ConnectBrowseButton"
                                VerticalAlignment="Bottom"
                                Content="Browse…"
                                Click="BrowseButton_Click" />
                        </Grid>
                        <CheckBox
                            MinWidth="0"
                            Content="{x:Bind OrgSubfolderLabel(ViewModel.Organization), Mode=OneWay}"
                            IsChecked="{x:Bind ViewModel.CreateOrgSubfolder, Mode=TwoWay}" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap"
                            Visibility="{x:Bind local:StatusFormat.VisibleIfNotEmpty(ViewModel.TargetPreview), Mode=OneWay}">
                            <Run Text="Each repository will be placed at:" />
                            <Run FontWeight="SemiBold" Text="{x:Bind ViewModel.TargetPreview, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                    </ContentControl>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button
                            MinWidth="140"
                            AutomationProperties.AutomationId="LoadReposButton"
                            Style="{StaticResource AccentButtonStyle}"
                            Content="Load repositories"
                            Command="{x:Bind ViewModel.LoadReposCommand, Mode=OneTime}">
                            <Button.KeyboardAccelerators>
                                <KeyboardAccelerator Key="R" Modifiers="Control" />
                            </Button.KeyboardAccelerators>
                        </Button>
                        <ProgressRing
                            Width="20"
                            Height="20"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="Loading repositories"
                            IsActive="{x:Bind ViewModel.IsLoadingRepos, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- ============================================================ State 2
             Connection chip + hero table card, once repositories have loaded. -->
        <Grid
            Grid.Row="0"
            RowSpacing="12"
            Visibility="{x:Bind local:StatusFormat.VisibleIf(ViewModel.HasLoadedRepos), Mode=OneWay}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Connection chip: what this workspace is connected to, and where clones land. -->
            <Border
                Grid.Row="0"
                HorizontalAlignment="Left"
                Padding="12,6"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="16">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon
                        FontSize="14"
                        VerticalAlignment="Center"
                        AutomationProperties.AccessibilityView="Raw"
                        Glyph="&#xE77B;" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.Organization, Mode=OneWay}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        AutomationProperties.AccessibilityView="Raw"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="·" />
                    <TextBlock
                        x:Name="ChipRepoCountText"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        AutomationProperties.AccessibilityView="Raw"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="·" />
                    <TextBlock
                        MaxWidth="280"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextTrimming="CharacterEllipsis"
                        ToolTipService.ToolTip="{x:Bind ViewModel.EffectiveTargetRoot, Mode=OneWay}"
                        Text="{x:Bind ViewModel.EffectiveTargetRoot, Mode=OneWay}" />
                    <HyperlinkButton
                        Padding="4,0"
                        VerticalAlignment="Center"
                        AutomationProperties.AutomationId="ChipEditButton"
                        AutomationProperties.Name="Edit connection"
                        Content="Edit"
                        Click="EditButton_Click">
                        <FlyoutBase.AttachedFlyout>
                            <Flyout x:Name="EditFlyout" Placement="Bottom" Opening="EditFlyout_Opening">
                                <StackPanel Width="360" Spacing="12">
                                    <TextBlock
                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        TextWrapping="Wrap"
                                        Text="Account settings are edited in the account wizard (next update)."
                                        Visibility="{x:Bind local:StatusFormat.VisibleIf(IsAccountWorkspace), Mode=OneTime}" />
                                    <ContentControl
                                        HorizontalContentAlignment="Stretch"
                                        IsEnabled="{x:Bind ConnectFieldsEnabled(ViewModel.CanEditInputs), Mode=OneWay}"
                                        IsTabStop="False">
                                    <StackPanel Spacing="12">
                                        <PasswordBox
                                            x:Name="EditTokenBox"
                                            Header="Personal access token"
                                            PlaceholderText="ghp_…"
                                            PasswordChanged="TokenBox_PasswordChanged" />
                                        <HyperlinkButton
                                            Padding="0"
                                            Content="How to create a token"
                                            NavigateUri="https://github.com/settings/tokens" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ComboBox
                                                Grid.Column="0"
                                                HorizontalAlignment="Stretch"
                                                Header="Organization or account"
                                                IsEditable="True"
                                                ItemsSource="{x:Bind ViewModel.Organizations, Mode=OneTime}"
                                                PlaceholderText="Paste a token first, or type an org"
                                                Text="{x:Bind ViewModel.Organization, Mode=TwoWay}" />
                                            <ProgressRing
                                                Grid.Column="1"
                                                Width="20"
                                                Height="20"
                                                Margin="0,0,0,8"
                                                VerticalAlignment="Bottom"
                                                AutomationProperties.Name="Loading organizations"
                                                IsActive="{x:Bind ViewModel.IsLoadingOrgs, Mode=OneWay}" />
                                        </Grid>
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox
                                                Grid.Column="0"
                                                Header="Target folder"
                                                PlaceholderText="C:\src\my-org"
                                                Text="{x:Bind ViewModel.TargetFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button
                                                Grid.Column="1"
                                                VerticalAlignment="Bottom"
                                                Content="Browse…"
                                                Click="BrowseButton_Click" />
                                        </Grid>
                                        <CheckBox
                                            MinWidth="0"
                                            Content="{x:Bind OrgSubfolderLabel(ViewModel.Organization), Mode=OneWay}"
                                            IsChecked="{x:Bind ViewModel.CreateOrgSubfolder, Mode=TwoWay}" />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            TextWrapping="Wrap"
                                            Visibility="{x:Bind local:StatusFormat.VisibleIfNotEmpty(ViewModel.TargetPreview), Mode=OneWay}">
                                            <Run Text="Each repository will be placed at:" />
                                            <Run FontWeight="SemiBold" Text="{x:Bind ViewModel.TargetPreview, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                    </ContentControl>
                                </StackPanel>
                            </Flyout>
                        </FlyoutBase.AttachedFlyout>
                    </HyperlinkButton>
                </StackPanel>
            </Border>

            <!-- Hero table card: toolbar, active strip, results InfoBar, header, rows. -->
            <Grid
                Grid.Row="1"
                Padding="12"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Toolbar: filter | selection summary (trims) | options / refresh / sync,
                     with the right side swapping to live progress + Cancel while running.
                     The XAML default is the narrow layout (actions on their own row); the
                     ToolbarSingleRow visual state lifts them beside the filter when the
                     measured widths fit — see UpdateToolbarLayout, which responds to any
                     width pressure (window size, text scaling, localization). -->
                <Grid
                    x:Name="ToolbarGrid"
                    Grid.Row="0"
                    ColumnSpacing="12"
                    SizeChanged="Toolbar_SizeChanged">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <SelectorBar
                        x:Name="FilterSelectorBar"
                        AutomationProperties.AutomationId="RepoFilterBar"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        SelectionChanged="FilterSelectorBar_SelectionChanged">
                        <SelectorBarItem x:Name="FilterAllItem" Text="All" Tag="All" />
                        <SelectorBarItem Text="Active" Tag="Active" />
                        <SelectorBarItem Text="Failed" Tag="Failed" />
                        <SelectorBarItem Text="Pending" Tag="Pending" />
                    </SelectorBar>
                    <TextBlock
                        x:Name="SelectionSummaryText"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        TextTrimming="CharacterEllipsis"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <StackPanel
                        x:Name="IdleActions"
                        Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Spacing="8"
                        SizeChanged="Toolbar_SizeChanged"
                        Visibility="{x:Bind local:StatusFormat.VisibleIfNot(ViewModel.IsRunning), Mode=OneWay}">
                        <Button
                            x:Name="OptionsButton"
                            AutomationProperties.AutomationId="SyncOptionsButton"
                            AutomationProperties.Name="Sync options"
                            ToolTipService.ToolTip="Sync options">
                            <FontIcon FontSize="16" Glyph="&#xE713;" />
                            <Button.Flyout>
                                <Flyout Placement="Bottom">
                                    <ContentControl
                                        HorizontalContentAlignment="Stretch"
                                        IsEnabled="{x:Bind ViewModel.CanEditInputs, Mode=OneWay}"
                                        IsTabStop="False">
                                    <StackPanel Width="320" Spacing="12">
                                        <NumberBox
                                            Header="Parallel clones"
                                            Minimum="1"
                                            Maximum="64"
                                            SpinButtonPlacementMode="Inline"
                                            ToolTipService.ToolTip="How many repositories are cloned or pulled at the same time"
                                            Value="{x:Bind ViewModel.MaxConcurrencyValue, Mode=TwoWay}" />
                                        <CheckBox
                                            MinWidth="0"
                                            Content="{x:Bind OrgSubfolderLabel(ViewModel.Organization), Mode=OneWay}"
                                            IsChecked="{x:Bind ViewModel.CreateOrgSubfolder, Mode=TwoWay}" />
                                        <TextBlock
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            TextWrapping="Wrap"
                                            Visibility="{x:Bind local:StatusFormat.VisibleIfNotEmpty(ViewModel.TargetPreview), Mode=OneWay}">
                                            <Run Text="Each repository will be placed at:" />
                                            <Run FontWeight="SemiBold" Text="{x:Bind ViewModel.TargetPreview, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                    </ContentControl>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        <Button
                            AutomationProperties.AutomationId="RefreshButton"
                            Content="Refresh"
                            Command="{x:Bind ViewModel.LoadReposCommand, Mode=OneTime}">
                            <Button.KeyboardAccelerators>
                                <KeyboardAccelerator Key="R" Modifiers="Control" />
                            </Button.KeyboardAccelerators>
                        </Button>
                        <Button
                            MinWidth="120"
                            AutomationProperties.AutomationId="SyncButton"
                            Style="{StaticResource AccentButtonStyle}"
                            Content="{x:Bind ViewModel.SyncButtonLabel, Mode=OneWay}"
                            Command="{x:Bind ViewModel.SyncCommand, Mode=OneTime}">
                            <Button.KeyboardAccelerators>
                                <KeyboardAccelerator Key="Enter" Modifiers="Control" />
                            </Button.KeyboardAccelerators>
                        </Button>
                    </StackPanel>
                    <StackPanel
                        x:Name="RunningActions"
                        Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Spacing="8"
                        SizeChanged="Toolbar_SizeChanged"
                        Visibility="{x:Bind local:StatusFormat.VisibleIf(ViewModel.IsRunning), Mode=OneWay}">
                        <ProgressBar
                            Width="120"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="Overall sync progress"
                            Maximum="{x:Bind ViewModel.TotalCount, Mode=OneWay}"
                            Value="{x:Bind ViewModel.CompletedCount, Mode=OneWay}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            Text="{x:Bind local:StatusFormat.RunProgressText(ViewModel.CompletedCount, ViewModel.TotalCount), Mode=OneWay}" />
                        <Button
                            AutomationProperties.AutomationId="CancelSyncButton"
                            Content="Cancel"
                            Command="{x:Bind ViewModel.SyncCancelCommand, Mode=OneTime}">
                            <Button.KeyboardAccelerators>
                                <KeyboardAccelerator Key="Escape" />
                            </Button.KeyboardAccelerators>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Active strip: exactly the repos cloning/pulling right now, bounded by
                     the parallelism setting, so the table never moves under the user. -->
                <ItemsControl
                    x:Name="ActiveStrip"
                    Grid.Row="1"
                    Margin="0,8,0,0"
                    MaxHeight="64"
                    AutomationProperties.Name="Repositories syncing now"
                    ItemsSource="{x:Bind ViewModel.ActiveRepos, Mode=OneTime}"
                    Visibility="{x:Bind local:StatusFormat.VisibleIf(ViewModel.IsRunning), Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VariableSizedWrapGrid Orientation="Horizontal" ItemWidth="208" ItemHeight="30" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:RepoItemViewModel">
                            <Border
                                Margin="0,0,8,4"
                                Padding="10,4"
                                Background="{ThemeResource ControlFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="13">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                        TextTrimming="CharacterEllipsis"
                                        Text="{x:Bind Name, Mode=OneTime}" />
                                    <ProgressBar
                                        Grid.Column="1"
                                        Width="56"
                                        VerticalAlignment="Center"
                                        AutomationProperties.Name="{x:Bind local:StatusFormat.ProgressAutomationName(Name), Mode=OneTime}"
                                        Maximum="1"
                                        Value="{x:Bind ProgressValue, Mode=OneWay}"
                                        IsIndeterminate="{x:Bind IsIndeterminate, Mode=OneWay}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Run results: opens when a run ends, user-dismissable (two-way IsOpen). -->
                <InfoBar
                    Grid.Row="2"
                    AutomationProperties.AutomationId="ResultInfoBar"
                    Margin="0,8,0,0"
                    IsOpen="{x:Bind ViewModel.ResultOpen, Mode=TwoWay}"
                    Severity="{x:Bind local:StatusFormat.SeverityFor(ViewModel.ResultKind), Mode=OneWay}"
                    Title="{x:Bind local:StatusFormat.TitleFor(ViewModel.ResultKind), Mode=OneWay}"
                    Message="{x:Bind ViewModel.ResultMessage, Mode=OneWay}">
                    <StackPanel
                        Margin="0,0,0,12"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            Content="Retry failed"
                            Command="{x:Bind ViewModel.RetryFailedCommand, Mode=OneTime}"
                            Visibility="{x:Bind local:StatusFormat.VisibleIf(ViewModel.HasFailedRepos), Mode=OneWay}" />
                        <Button Content="Open folder" Click="OpenFolderButton_Click" />
                    </StackPanel>
                </InfoBar>

                <!-- Table header: fixed column widths mirrored by the row template below.
                     Every column sorts (button, composed automation name like
                     "Name, sorted ascending") and filters (funnel flyout; the funnel
                     turns accent-colored while its filter is active). The header row
                     itself gets subtle chrome to read as a header, not a data row. -->
                <Border
                    Grid.Row="3"
                    Margin="0,8,0,0"
                    Padding="12,2,12,2"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="4,4,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <CheckBox
                            Grid.Column="0"
                            MinWidth="0"
                            Padding="0"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="Select all"
                            AutomationProperties.Name="Select all repositories"
                            IsChecked="{x:Bind ViewModel.AllSelected, Mode=TwoWay}" />

                        <Grid Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button
                                Style="{StaticResource ColumnHeaderButtonStyle}"
                                AutomationProperties.Name="{x:Bind SortAutomationName('Name', ViewModel.SortColumn, ViewModel.SortDescending), Mode=OneWay}"
                                Command="{x:Bind ViewModel.SortCommand, Mode=OneTime}"
                                CommandParameter="Name">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock FontWeight="SemiBold" Text="Name" />
                                    <FontIcon
                                        FontSize="10"
                                        VerticalAlignment="Center"
                                        AutomationProperties.AccessibilityView="Raw"
                                        Glyph="{x:Bind SortGlyph('Name', ViewModel.SortColumn, ViewModel.SortDescending), Mode=OneWay}"
                                        Visibility="{x:Bind SortGlyphVisibility('Name', ViewModel.SortColumn), Mode=OneWay}" />
                                </StackPanel>
                            </Button>
                            <Button
                                Grid.Column="1"
                                Style="{StaticResource ColumnFilterButtonStyle}"
                                AutomationProperties.AutomationId="NameFilterButton"
                                AutomationProperties.Name="{x:Bind TextFilterAutomationName('name', ViewModel.NameFilter), Mode=OneWay}"
                                ToolTipService.ToolTip="Filter by name">
                                <FontIcon
                                    FontSize="12"
                                    Glyph="&#xE71C;"
                                    Foreground="{x:Bind TextFilterIndicatorBrush(ViewModel.NameFilter), Mode=OneWay}" />
                                <Button.Flyout>
                                    <Flyout Placement="Bottom">
                                        <StackPanel Width="220" Spacing="8">
                                            <TextBox
                                                Header="Name contains"
                                                AutomationProperties.AutomationId="NameFilterBox"
                                                Text="{x:Bind ViewModel.NameFilter, Mode=OneWay}"
                                                TextChanged="NameFilterBox_TextChanged" />
                                            <Button
                                                HorizontalAlignment="Right"
                                                Content="Clear"
                                                Click="ClearNameFilter_Click" />
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>

                        <Grid Grid.Column="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button
                                Style="{StaticResource ColumnHeaderButtonStyle}"
                                AutomationProperties.Name="{x:Bind SortAutomationName('Status', ViewModel.SortColumn, ViewModel.SortDescending), Mode=OneWay}"
                                Command="{x:Bind ViewModel.SortCommand, Mode=OneTime}"
                                CommandParameter="Status">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock FontWeight="SemiBold" Text="Status" />
                                    <FontIcon
                                        FontSize="10"
                                        VerticalAlignment="Center"
                                        AutomationProperties.AccessibilityView="Raw"
                                        Glyph="{x:Bind SortGlyph('Status', ViewModel.SortColumn, ViewModel.SortDescending), Mode=OneWay}"
                                        Visibility="{x:Bind SortGlyphVisibility('Status', ViewModel.SortColumn), Mode=OneWay}" />
                                </StackPanel>
                            </Button>
                            <Button
                                Grid.Column="1"
                                Style="{StaticResource ColumnFilterButtonStyle}"
                                AutomationProperties.AutomationId="StatusFilterButton"
                                AutomationProperties.Name="{x:Bind StatusFilterAutomationName(ViewModel.Filter), Mode=OneWay}"
                                ToolTipService.ToolTip="Filter by status">
                                <FontIcon
                                    FontSize="12"
                                    Glyph="&#xE71C;"
                                    Foreground="{x:Bind StatusFilterIndicatorBrush(ViewModel.Filter), Mode=OneWay}" />
                                <Button.Flyout>
                                    <Flyout Placement="Bottom">
                                        <RadioButtons
                                            Header="Show"
                                            AutomationProperties.AutomationId="StatusFilterChoices"
                                            SelectedIndex="{x:Bind StatusFilterIndex(ViewModel.Filter), Mode=OneWay}"
                                            SelectionChanged="StatusFilterChoices_SelectionChanged">
                                            <x:String>All</x:String>
                                            <x:String>Active</x:String>
                                            <x:String>Failed</x:String>
                                            <x:String>Pending</x:String>
                                        </RadioButtons>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>

                        <Grid Grid.Column="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button
                                Style="{StaticResource ColumnHeaderButtonStyle}"
                                AutomationProperties.Name="{x:Bind SortAutomationName('Branch', ViewModel.SortColumn, ViewModel.SortDescending), Mode=OneWay}"
                                Command="{x:Bind ViewModel.SortCommand, Mode=OneTime}"
                                CommandParameter="Branch">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock FontWeight="SemiBold" Text="Branch" />
                                    <FontIcon
                                        FontSize="10"
                                        VerticalAlignment="Center"
                                        AutomationProperties.AccessibilityView="Raw"
                                        Glyph="{x:Bind SortGlyph('Branch', ViewModel.SortColumn, ViewModel.SortDescending), Mode=OneWay}"
                                        Visibility="{x:Bind SortGlyphVisibility('Branch', ViewModel.SortColumn), Mode=OneWay}" />
                                </StackPanel>
                            </Button>
                            <Button
                                Grid.Column="1"
                                Style="{StaticResource ColumnFilterButtonStyle}"
                                AutomationProperties.AutomationId="BranchFilterButton"
                                AutomationProperties.Name="{x:Bind TextFilterAutomationName('branch', ViewModel.BranchFilter), Mode=OneWay}"
                                ToolTipService.ToolTip="Filter by branch">
                                <FontIcon
                                    FontSize="12"
                                    Glyph="&#xE71C;"
                                    Foreground="{x:Bind TextFilterIndicatorBrush(ViewModel.BranchFilter), Mode=OneWay}" />
                                <Button.Flyout>
                                    <Flyout Placement="Bottom">
                                        <StackPanel Width="220" Spacing="8">
                                            <TextBox
                                                Header="Branch contains"
                                                AutomationProperties.AutomationId="BranchFilterBox"
                                                Text="{x:Bind ViewModel.BranchFilter, Mode=OneWay}"
                                                TextChanged="BranchFilterBox_TextChanged" />
                                            <Button
                                                HorizontalAlignment="Right"
                                                Content="Clear"
                                                Click="ClearBranchFilter_Click" />
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>

                        <Grid Grid.Column="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button
                                Style="{StaticResource ColumnHeaderButtonStyle}"
                                AutomationProperties.Name="{x:Bind SortAutomationName('Archived', ViewModel.SortColumn, ViewModel.SortDescending), Mode=OneWay}"
                                Command="{x:Bind ViewModel.SortCommand, Mode=OneTime}"
                                CommandParameter="Archived">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock FontWeight="SemiBold" Text="Archived" />
                                    <FontIcon
                                        FontSize="10"
                                        VerticalAlignment="Center"
                                        AutomationProperties.AccessibilityView="Raw"
                                        Glyph="{x:Bind SortGlyph('Archived', ViewModel.SortColumn, ViewModel.SortDescending), Mode=OneWay}"
                                        Visibility="{x:Bind SortGlyphVisibility('Archived', ViewModel.SortColumn), Mode=OneWay}" />
                                </StackPanel>
                            </Button>
                            <Button
                                Grid.Column="1"
                                Style="{StaticResource ColumnFilterButtonStyle}"
                                AutomationProperties.AutomationId="ArchivedFilterButton"
                                AutomationProperties.Name="{x:Bind ArchivedFilterAutomationName(ViewModel.ArchivedFilter), Mode=OneWay}"
                                ToolTipService.ToolTip="Filter by archived">
                                <FontIcon
                                    FontSize="12"
                                    Glyph="&#xE71C;"
                                    Foreground="{x:Bind ArchivedFilterIndicatorBrush(ViewModel.ArchivedFilter), Mode=OneWay}" />
                                <Button.Flyout>
                                    <Flyout Placement="Bottom">
                                        <RadioButtons
                                            Header="Show"
                                            AutomationProperties.AutomationId="ArchivedFilterChoices"
                                            SelectedIndex="{x:Bind ArchivedFilterIndex(ViewModel.ArchivedFilter), Mode=OneWay}"
                                            SelectionChanged="ArchivedFilterChoices_SelectionChanged">
                                            <x:String>All</x:String>
                                            <x:String>Archived only</x:String>
                                            <x:String>Not archived</x:String>
                                        </RadioButtons>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Per-repo table body. The ListView carries the view model as DataContext so
                     the row template's Resolve link can reach WorkspaceViewModel.ResolvePathsCommand
                     via ElementName (x:Bind inside the template is scoped to the row item). -->
                <ListView
                    x:Name="RepoListView"
                    AutomationProperties.AutomationId="RepoListView"
                    Grid.Row="4"
                    DataContext="{x:Bind ViewModel, Mode=OneTime}"
                    ItemsSource="{x:Bind ViewModel.FilteredRepos, Mode=OneTime}"
                    SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="12,0,12,0" />
                            <Setter Property="MinHeight" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:RepoItemViewModel">
                            <Grid Padding="0,6,0,6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <CheckBox
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    MinWidth="0"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="{x:Bind Name, Mode=OneTime}"
                                    IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    FontWeight="SemiBold"
                                    TextTrimming="CharacterEllipsis"
                                    Text="{x:Bind Name, Mode=OneTime}" />
                                <StackPanel
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center"
                                    Spacing="2">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon
                                            FontSize="12"
                                            VerticalAlignment="Center"
                                            Glyph="{x:Bind local:StatusFormat.GlyphFor(Status), Mode=OneWay}"
                                            Foreground="{x:Bind local:StatusFormat.BrushFor(Status), Mode=OneWay}" />
                                        <TextBlock
                                            Text="{x:Bind StatusText, Mode=OneWay}"
                                            Foreground="{x:Bind local:StatusFormat.BrushFor(Status), Mode=OneWay}" />
                                    </StackPanel>
                                    <ProgressBar
                                        Maximum="1"
                                        Value="{x:Bind ProgressValue, Mode=OneWay}"
                                        IsIndeterminate="{x:Bind IsIndeterminate, Mode=OneWay}"
                                        Visibility="{x:Bind local:StatusFormat.VisibleIf(ShowProgress), Mode=OneWay}" />
                                </StackPanel>
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="3"
                                    VerticalAlignment="Center"
                                    TextTrimming="CharacterEllipsis"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind BranchText, Mode=OneTime}" />
                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="4"
                                    VerticalAlignment="Center"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Archived"
                                    Visibility="{x:Bind local:StatusFormat.VisibleIf(IsArchived), Mode=OneTime}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="5"
                                    TextWrapping="Wrap"
                                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                    Text="{x:Bind Error, Mode=OneWay}"
                                    Visibility="{x:Bind local:StatusFormat.VisibleIf(HasError), Mode=OneWay}" />
                                <HyperlinkButton
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="5"
                                    Padding="0"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="{x:Bind local:StatusFormat.ResolveAutomationName(Name), Mode=OneTime}"
                                    Content="Resolve…"
                                    Command="{Binding DataContext.ResolvePathsCommand, ElementName=RepoListView}"
                                    CommandParameter="{x:Bind}"
                                    Visibility="{x:Bind local:StatusFormat.VisibleIf(HasPathIssue), Mode=OneWay}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Shown when the current filter hides everything the table has. -->
                <TextBlock
                    x:Name="EmptyFilterText"
                    Grid.Row="4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="No repositories match this filter."
                    Visibility="Collapsed" />
            </Grid>
        </Grid>

        <!-- Load-phase status and the page's assistive-technology live region. Kept in
             the tree (with its name) so announcements keep working in both states. -->
        <TextBlock
            x:Name="StatusTextBlock"
            AutomationProperties.AutomationId="StatusTextBlock"
            Grid.Row="1"
            AutomationProperties.LiveSetting="Polite"
            Style="{ThemeResource CaptionTextBlockStyle}"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
            TextWrapping="Wrap" />
    </Grid>
</UserControl>
